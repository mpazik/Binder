{
  "name": "binder-vscode",
  "displayName": "Binder",
  "description": "Language support for Binder - Git-inspired knowledge graph for Markdown",
  "version": "0.1.1",
  "publisher": "Binder",
  "license": "MIT",
  "homepage": "https://binder.do",
  "repository": {
    "type": "git",
    "url": "https://github.com/mpazik/binder"
  },
  "bugs": {
    "url": "https://github.com/mpazik/binder/issues"
  },
  "keywords": [
    "markdown",
    "knowledge-base",
    "notes",
    "yaml",
    "language-server",
    "lsp",
    "binder"
  ],
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "workspaceContains:.binder"
  ],
  "contributes": {
    "configurationDefaults": {
      "[markdown]": {
        "editor.quickSuggestions": {
          "other": true,
          "comments": false,
          "strings": false
        }
      }
    },
    "configuration": {
      "type": "object",
      "title": "Binder",
      "properties": {
        "binder.command": {
          "type": "string",
          "default": "binder",
          "description": "Command to run the Binder CLI",
          "scope": "machine-overridable"
        },
        "binder.logLevel": {
          "type": "string",
          "enum": [
            "info",
            "debug"
          ],
          "default": "info",
          "description": "Log level for the Binder language server",
          "scope": "window"
        },
        "binderLsp.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the Binder language server",
          "scope": "window"
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify",
    "watch": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "typecheck": "tsc --noEmit",
    "prepackage": "npm run build",
    "package": "vsce package --out out"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.0.0"
  }
}
