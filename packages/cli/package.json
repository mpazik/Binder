{
  "name": "@binder.do/cli",
  "version": "0.1.2",
  "description": "Local-first knowledge base with bidirectional Markdown sync, LSP, MCP, and CLI",
  "license": "MIT",
  "author": "Marek Pazik",
  "homepage": "https://binder.do",
  "repository": {
    "type": "git",
    "url": "https://github.com/mpazik/binder",
    "directory": "packages/cli"
  },
  "keywords": [
    "knowledge-base",
    "knowledge-graph",
    "markdown",
    "sqlite",
    "yaml",
    "graph-database",
    "lsp",
    "mcp",
    "cli",
    "local-first"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "binder": "./dist/index.js"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "NODE_ENV=development bun run build.ts",
    "build:prod": "NODE_ENV=production bun run build.ts --prod",
    "prepublishOnly": "rm -rf dist && cp ../../README.md . && bun run build.ts --prod",
    "postpublish": "rm -f README.md",
    "format": "bun prettier --write --ignore-path ../../.prettierignore .",
    "lint": "bun eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "bun test src/",
    "test:e2e": "bun test ./tests/",
    "test:e2e:node": "BINDER_CLI=\"node $PWD/dist/index.js\" bun test ./tests/",
    "check": "bun lint && bun format && bun typecheck && bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "release": "release-it"
  },
  "release-it": {
    "git": {
      "commitMessage": "release: v${version}"
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "conventionalcommits"
      }
    },
    "hooks": {
      "before:init": [
        "[ $(git branch --show-current) = main ] || (echo 'Must be on main branch' && exit 1)",
        "cd ../.. && bun run check:verify"
      ]
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0"
  },
  "devDependencies": {
    "@binder/db": "workspace:*",
    "@binder/utils": "workspace:*",
    "@clack/prompts": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/mdast": "^4.0.4",
    "@types/picomatch": "^4.0.2",
    "@types/yargs": "^17.0.35",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "handlebars": "^4.7.8",
    "mdast": "^3.0.0",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-frontmatter": "^2.0.1",
    "mdast-util-to-markdown": "^2.1.2",
    "micromark-util-types": "^2.0.2",
    "picomatch": "^4.0.4",
    "release-it": "^19.2.4",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-parse-frontmatter": "^1.0.3",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "yaml": "^2.8.3",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  }
}
